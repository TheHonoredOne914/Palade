{
  "name": "palade",
  "version": "1.0.0-rc.1",
  "description": "AI-powered codebase intelligence — reviewed by a swarm, not a single bot.",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheHonoredOne914/Palade.git"
  },
  "bugs": {
    "url": "https://github.com/TheHonoredOne914/Palade/issues"
  },
  "homepage": "https://github.com/TheHonoredOne914/Palade#readme",
  "author": "TheHonoredOne914",
  "type": "module",
  "bin": {
    "palade": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "templates/",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "code-review",
    "ai",
    "swarm",
    "codebase",
    "health-score",
    "static-analysis",
    "cli"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "prepublishOnly": "npm run clean && npm run build && npm run format:check && npm test"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^4.0.1",
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "ignore": "^7.0.3",
    "ink": "^7.1.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "open": "^10.1.0",
    "p-limit": "^6.2.0",
    "react": "^19.2.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "typescript-eslint": "^8.62.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "eslint": "^10.6.0",
    "prettier": "^3.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
